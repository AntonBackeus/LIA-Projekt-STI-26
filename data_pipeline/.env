#Database config
DB_HOST = "timescaledb"             #The name of the docker compose service for the database, make sure they match so other services can find it
DB_PASS = "secret"                  #Database user password, change this on a user basis for security. Changes should NOT be uploaded to github
DB_USER = "admin"                   #Database user username, change this on a user basis for security. Changes should NOT be uploaded to github
DB_PORT = 5432                      #Database port, keep as "5432" unless absolutely necessary as 5432 is standard postgres
DB_NAME = "appdb"                   #Database name, change to match product use. Changes are prefered to be done on user basis but can be in github

#Grafana config
PROVISIONING_NAME = "Local Postgres"    #Name of the grafana connection to database, make sure it matches the name used to dashboard as it is hard coded in the dashboard json
PROVISIONING_TYPE = "postgres"          #Name of the connection type, keep as postgres since timescale is an extension of postgres
PROVISIONING_ACCESS = "proxy"           #How grafana access the database. Change if needed but should never be the problem
PROVISIONING_SSL = "disable"            #Disables more complicated connection settings. Enable a specific type only if familiar with how to implement it
PROVISIONING_POSTGRES_VERSION = 1400    #Describes with version is used in postgres. Make sure it matches the end of the postgres image, for example "pg14"
PROVISIONING_TIMESCALE_BOOL = true      #Makes sure grafana knows we are connecting to a timescale extension and not base postgres. Do not change
PROVISIONING_SCHEMA_NAME = "public"     #Which schema should be used in the dashboards. Can be changed but fixes errors on some machines so avoid removing if possible
PROVISIONING_CONNECTIONS = 100          #Amount of connections allowed, change if dashboard feels slow. Might not fix but worth a try. Use "100" if unsure
GRAFANA_PORT = 3000                     #Which port the grafana UI will show on. Might need a second one for the second dashboard if it cant run 2 at the same time