#Databas config
DB_HOST = "timescaledb"
DB_PASS = "secret"
DB_USER = "admin"
DB_PORT = 5432
DB_NAME = "appdb"

#MQTT config
MQTT_HOST = "emqx"
MQTT_PORT = 1883
MQTT_USER = "admin"
MQTT_PASS = "strongpassword"

#Grafana provisioning
GRAFANA_TYPE = "postgres"
GRAFANA_SSL = "disable"
GRAFANA_POSTGRES_VERSION = 1400
GRAFANA_TIMESCALE_BOOL = "true"
GRAFANA_SCHEMA_NAME = "public"
GRAFANA_CONNECTIONS = 100